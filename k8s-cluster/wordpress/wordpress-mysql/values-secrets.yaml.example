# =============================================================================
# values-secrets.yaml.example
# Copia este fichero a values-secrets.yaml y rellena con tus credenciales.
# values-secrets.yaml está en .helmignore y NO debe commitearse.
#
# Uso:
#   helm upgrade --install wp . -f values.yaml -f values-secrets.yaml
# =============================================================================

mysql-subchart:
  mysql:
    database: wordpress
    user: wordpress
    password: "REEMPLAZA_CON_PASSWORD_SEGURA"
    rootPassword: "REEMPLAZA_CON_ROOT_PASSWORD_SEGURA"
